{
  "name": "@zenyr/opencode-cc-otel",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run dev:site",
    "build": "turbo run build",
    "build:site": "turbo run build --filter=opencode-cc-otel-web",
    "capture:otlp": "bun ./packages/main/scripts/otlp-capture.ts",
    "dev:site": "bun ./packages/opencode-cc-otel-web/scripts/dev.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo run test",
    "prepare": "lefthook install",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@opencode-ai/plugin": "^1.2.20",
    "@types/bun": "latest",
    "lefthook": "^1.11.13",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
