{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zenyr.github.io/opencode-cc-otel/schemas/telemetry.schema.json",
  "title": "OpenCode Telemetry Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional hosted schema URL for editor validation."
    },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstParty": {
          "$ref": "#/$defs/firstPartyChannel"
        },
        "secondParty": {
          "$ref": "#/$defs/secondPartyChannel"
        },
        "thirdParty": {
          "$ref": "#/$defs/thirdPartyChannel"
        }
      }
    },
    "providerFilter": {
      "$ref": "#/$defs/providerFilter"
    }
  },
  "$defs": {
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "description": "HTTPS telemetry endpoint."
    },
    "tokenValue": {
      "type": "string",
      "minLength": 1,
      "description": "Bearer token or env indirection like env:OPENCODE_CC_OTEL_HTTP_TOKEN."
    },
    "httpTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "$ref": "#/$defs/httpsUrl"
        },
        "token": {
          "$ref": "#/$defs/tokenValue"
        }
      },
      "required": ["endpoint"]
    },
    "httpConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "$ref": "#/$defs/httpTarget"
        }
      }
    },
    "otelConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceName": {
          "type": "string",
          "minLength": 1,
          "description": "Override service.name for secondParty OTEL sink. Supports env:NAME."
        },
        "serviceVersion": {
          "type": "string",
          "minLength": 1,
          "description": "Override service.version for secondParty OTEL sink. Supports env:NAME."
        },
        "logsChannelId": {
          "type": "string",
          "minLength": 1,
          "description": "Override OTEL logs channel id. Supports env:NAME."
        },
        "metricsChannelId": {
          "type": "string",
          "minLength": 1,
          "description": "Override OTEL metrics channel id. Supports env:NAME."
        },
        "resourceAttributes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Extra OTEL resource attrs for team or enterprise reporting."
        }
      }
    },
    "secondPartyFileConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "NDJSON file path for secondParty file transport. Supports env:NAME."
        }
      }
    },
    "firstPartyChannel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "FirstParty reporting defaults off. Set true to opt in."
        },
        "sink": {
          "const": "http",
          "description": "Anthropic 1P payload contract. Current delivery is HTTP batch only."
        },
        "http": {
          "$ref": "#/$defs/httpConfig"
        }
      },
      "required": ["sink"]
    },
    "secondPartyChannel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "sink": {
          "const": "otel-json",
          "description": "SecondParty payload contract. Claude-style OTEL JSON logs and metrics."
        },
        "transport": {
          "type": "string",
          "enum": ["file", "console"],
          "description": "SecondParty delivery medium. `file` is the default local-safe path; `console` remains available for direct output."
        },
        "file": {
          "$ref": "#/$defs/secondPartyFileConfig"
        },
        "otel": {
          "$ref": "#/$defs/otelConfig"
        }
      },
      "required": ["sink"]
    },
    "thirdPartyChannel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "const": false,
          "description": "thirdParty forwarding unsupported yet. Must stay false when present."
        }
      }
    },
    "providerFilter": {
      "type": "object",
      "additionalProperties": false,
      "description": "Filter telemetry by LLM provider. When set, only matching providers are logged.",
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Provider IDs to log (e.g. [\"anthropic\"]). Events from unlisted providers are dropped. Provider-agnostic events (tool, permission, command, diff) are only emitted while the active provider matches."
        }
      },
      "required": ["allow"]
    }
  },
  "examples": [
    {
      "providerFilter": {
        "allow": ["anthropic"]
      },
      "channels": {
        "firstParty": {
          "enabled": false,
          "sink": "http",
          "http": {
            "default": {
              "endpoint": "https://api.anthropic.com/api/event_logging/batch",
              "token": "env:OPENCODE_CC_OTEL_HTTP_TOKEN_1P"
            }
          }
        },
        "secondParty": {
          "enabled": true,
          "sink": "otel-json",
          "transport": "file",
          "file": {
            "path": "env:OPENCODE_CC_OTEL_2P_FILE_PATH"
          },
          "otel": {
            "serviceName": "claude-code",
            "serviceVersion": "env:OPENCODE_CC_OTEL_SERVICE_VERSION",
            "logsChannelId": "otel_3p_logs",
            "metricsChannelId": "otel_3p_metrics",
            "resourceAttributes": {
              "user.subscription_type": "team"
            }
          }
        },
        "thirdParty": {
          "enabled": false
        }
      }
    }
  ]
}
