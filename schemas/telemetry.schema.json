{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zenyr.github.io/opencode-cc-otel/schemas/telemetry.schema.json",
  "title": "OpenCode Telemetry Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional hosted schema URL for editor validation."
    },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstParty": {
          "$ref": "#/$defs/firstPartyChannel"
        },
        "secondParty": {
          "$ref": "#/$defs/secondPartyChannel"
        },
        "thirdParty": {
          "$ref": "#/$defs/thirdPartyChannel"
        }
      }
    }
  },
  "$defs": {
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "description": "HTTPS telemetry endpoint."
    },
    "tokenValue": {
      "type": "string",
      "minLength": 1,
      "description": "Bearer token or env indirection like env:OPENCODE_TELEMETRY_HTTP_TOKEN."
    },
    "httpTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "$ref": "#/$defs/httpsUrl"
        },
        "token": {
          "$ref": "#/$defs/tokenValue"
        }
      },
      "required": ["endpoint"]
    },
    "httpConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "$ref": "#/$defs/httpTarget"
        }
      }
    },
    "otelConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceName": {
          "type": "string",
          "minLength": 1,
          "description": "Override service.name for secondParty OTEL sink. Supports env:NAME."
        },
        "serviceVersion": {
          "type": "string",
          "minLength": 1,
          "description": "Override service.version for secondParty OTEL sink. Supports env:NAME."
        },
        "logsChannelId": {
          "type": "string",
          "minLength": 1,
          "description": "Override OTEL logs channel id. Supports env:NAME."
        },
        "metricsChannelId": {
          "type": "string",
          "minLength": 1,
          "description": "Override OTEL metrics channel id. Supports env:NAME."
        },
        "resourceAttributes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Extra OTEL resource attrs for team or enterprise reporting."
        }
      }
    },
    "firstPartyChannel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "sink": {
          "const": "http",
          "description": "Anthropic 1P event logging uses HTTP batch only."
        },
        "http": {
          "$ref": "#/$defs/httpConfig"
        }
      },
      "required": ["sink"]
    },
    "secondPartyChannel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "sink": {
          "type": "string",
          "enum": ["otel-json", "console"],
          "description": "SecondParty team or enterprise reporting sink."
        },
        "otel": {
          "$ref": "#/$defs/otelConfig"
        }
      },
      "required": ["sink"]
    },
    "thirdPartyChannel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "const": false,
          "description": "thirdParty forwarding unsupported yet. Must stay false when present."
        }
      }
    }
  },
  "examples": [
    {
      "channels": {
        "firstParty": {
          "enabled": true,
          "sink": "http",
          "http": {
            "default": {
              "endpoint": "https://api.anthropic.com/api/event_logging/batch",
              "token": "env:OPENCODE_TELEMETRY_HTTP_TOKEN_1P"
            }
          }
        },
        "secondParty": {
          "enabled": true,
          "sink": "otel-json",
          "otel": {
            "serviceName": "claude-code",
            "serviceVersion": "env:OPENCODE_TELEMETRY_SERVICE_VERSION",
            "logsChannelId": "otel_3p_logs",
            "metricsChannelId": "otel_3p_metrics",
            "resourceAttributes": {
              "user.subscription_type": "team"
            }
          }
        },
        "thirdParty": {
          "enabled": false
        }
      }
    }
  ]
}
